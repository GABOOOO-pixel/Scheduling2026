<% layout('public') %>

<style>
  .login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 10% 5%, #052e16, transparent 25%),
      radial-gradient(circle at 95% 90%, #15803d, transparent 24%),
      radial-gradient(circle at 10% 60%, #14532d, transparent 30%);
    background-blend-mode: lighten;
    backdrop-filter: blur(10px);
    background-color: #052e16;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .login-wrapper::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(245, 158, 11, 0.12) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    border-radius: 50%;
  }
  .login-wrapper::after {
    content: '';
    position: absolute;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
    bottom: -100px;
    left: -100px;
    border-radius: 50%;
  }
  .login-card {
    background: rgba(255,255,255,0.97);
    border-radius: 20px;
    padding: 2.5rem;
    width: 100%;
    max-width: 520px;
    box-shadow: 0 25px 60px rgba(0,0,0,0.3);
    position: relative;
    z-index: 1;
  }
  .login-card .brand {
    text-align: center;
    margin-bottom: 2rem;
  }
  .login-card .brand h2 {
    font-weight: 800;
    font-size: 1.75rem;
    color: #0f172a;
  }
  .login-card .brand h2 span {
    color: #f59e0b;
  }
  .login-card .brand p {
    color: #64748b;
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
  .login-input {
    border: 2px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.7rem 1rem 0.7rem 2.75rem;
    font-size: 0.9rem;
    transition: all 0.2s;
    background: #f8fafc;
    width: 100%;
  }
  .login-input:focus {
    border-color: #1e3a5f;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(30, 58, 95, 0.08);
    outline: none;
  }
  .input-icon-wrapper {
    position: relative;
  }
  .input-icon-wrapper i {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .btn-login {
    background: #052e16;
    color: #fff;
    border: none;
    padding: 0.75rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    width: 100%;
    transition: all 0.2s;
    cursor: pointer;
  }
  .btn-login:hover {
    background: #14532d;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(30, 58, 95, 0.3);
  }
  .back-link {
    text-align: center;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e2e8f0;
  }
  .back-link a {
    color: #002707;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
  }
  .back-link a:hover {
    color: #d97706;
    text-decoration: underline;
  }
  .logo-card {
    display: flex !important;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 5px;
  }
  .logo {
    height: 95px;
    width: 95px;
  }
  .info-box {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    padding: 0.85rem 1rem;
    font-size: 0.82rem;
    color: #166534;
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
  }
  .info-box i {
    margin-top: 2px;
    flex-shrink: 0;
  }
</style>

<div class="login-wrapper">
  <div class="login-card">
    <div class="logo-card">
      <img src="/images/logo.png" alt="" class="logo">
    </div>
    <div class="brand">
      <h2><span>CIT </span>Schedule</h2>
      <p style="color: rgb(4, 40, 4) !important;">Forgot Password</p>
    </div>

    <%- include('./alerts') %>

    <div class="info-box">
      <i class="fas fa-info-circle"></i>
      <span>Enter your registered email address and we'll send you a link to reset your password.</span>
    </div>

    <form action="/fg" method="POST">
      <div class="mb-4">
        <label class="form-label" style="font-weight: 600; font-size: 0.8rem;">Email Address</label>
        <div class="input-icon-wrapper">
          <i class="fas fa-envelope"></i>
          <input
            type="email"
            name="email"
            class="login-input"
            placeholder="Enter your registered email"
            required
          />
        </div>
      </div>
      <button type="submit" class="btn btn-login">
        <i class="fas fa-paper-plane me-2"></i>Send Reset Link
      </button>
    </form>

    <div class="back-link">
      <a href="/"><i class="fas fa-arrow-left me-1"></i>Back to Login</a>
    </div>
  </div>
</div>
