<% layout('public') %>

<style>
  .error-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f172a, #1e3a5f);
    text-align: center;
    padding: 2rem;
  }
  .error-code {
    font-size: 8rem;
    font-weight: 900;
    color: #f59e0b;
    line-height: 1;
    text-shadow: 0 4px 20px rgba(245, 158, 11, 0.3);
  }
  .error-msg {
    color: #94a3b8;
    font-size: 1.1rem;
    margin: 1rem 0 2rem;
  }
  .btn-home {
    background: #f59e0b;
    color: #000;
    border: none;
    padding: 0.75rem 2rem;
    border-radius: 10px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-home:hover { background: #d97706; color: #000; transform: translateY(-2px); }
</style>

<div class="error-wrapper">
  <div>
    <div class="error-code">404</div>
    <h3 style="color: #fff; font-weight: 700;">Page Not Found</h3>
    <p class="error-msg"><%= typeof error !== 'undefined' && error ? error : 'The page you are looking for does not exist.' %></p>
    <a href="/" class="btn-home"><i class="fas fa-home me-2"></i>Go Home</a>
  </div>
</div>
