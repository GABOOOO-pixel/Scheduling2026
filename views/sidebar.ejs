<aside class="sidebar">
  <div class="sidebar-brand">
    <h4><span>CIT </span>Schedule</h4>
    <small style="color: var(--sidebar-text); font-size: 0.7rem;">Scheduling System</small>
  </div>

  <ul class="sidebar-nav">
    <!-- MAIN -->
    <li class="nav-label">Main</li>
    <li class="nav-item">
      <a href="/dashboard" class="<%= active === 'dashboard' ? 'active' : '' %>">
        <i class="fas fa-th-large"></i> Dashboard
      </a>
    </li>

    <% if (user && (user.role === 'super_admin' || user.role === 'admin')) { %>
      <!-- SCHEDULING -->
      <li class="nav-label">Scheduling</li>
      <li class="nav-item">
        <a href="/schedule" class="<%= active === 'schedule' ? 'active' : '' %>">
          <i class="fas fa-calendar-alt"></i> Schedules
        </a>
      </li>

      <!-- MANAGEMENT -->
      <li class="nav-label">Management</li>
      <li class="nav-item">
        <a href="/students" class="<%= active === 'students' ? 'active' : '' %>">
          <i class="fas fa-user-graduate"></i> Students
        </a>
      </li>
      <li class="nav-item">
        <a href="/subjects" class="<%= active === 'subjects' ? 'active' : '' %>">
          <i class="fas fa-book"></i> Subjects
        </a>
      </li>
      <li class="nav-item">
        <a href="/teachers" class="<%= active === 'teachers' ? 'active' : '' %>">
          <i class="fas fa-chalkboard-teacher"></i> Teachers
        </a>
      </li>
      <li class="nav-item">
        <a href="/sections" class="<%= active === 'sections' ? 'active' : '' %>">
          <i class="fas fa-layer-group"></i> Sections
        </a>
      </li>
      <li class="nav-item">
        <a href="/rooms" class="<%= active === 'rooms' ? 'active' : '' %>">
          <i class="fas fa-door-open"></i> Rooms
        </a>
      </li>
    <% } %>

    <% if (user && user.role === 'faculty') { %>
      <!-- FACULTY -->
      <li class="nav-label">My Area</li>
      <li class="nav-item">
        <a href="/my-schedule" class="<%= active === 'my-schedule' ? 'active' : '' %>">
          <i class="fas fa-calendar-check"></i> My Schedule
        </a>
      </li>
    <% } %>

    <% if (user && user.role === 'super_admin') { %>
      <!-- ADMIN AREA -->
      <li class="nav-label">Administration</li>
      <li class="nav-item">
        <a href="/users" class="<%= active === 'users' ? 'active' : '' %>">
          <i class="fas fa-users-cog"></i> User Accounts
        </a>
      </li>
      <li class="nav-item">
        <a href="/archive" class="<%= active === 'archive' ? 'active' : '' %>">
          <i class="fas fa-archive"></i> Archives
        </a>
      </li>
    <% } %>

    <!-- ACCOUNT -->
    <li class="nav-label">Account</li>
    <li class="nav-item">
      <a href="/profile" class="<%= active === 'profile' ? 'active' : '' %>">
        <i class="fas fa-user-circle"></i> Profile
      </a>
    </li>
    <li class="nav-item">
      <a href="/logout" style="color: #ffffff; background-color: #ffffff15;">
        <i class="fas fa-sign-out-alt"></i> Logout
      </a>
    </li>
  </ul>
</aside>
