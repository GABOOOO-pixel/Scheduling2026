<% layout('main') %>

<%- include('./sidebar') %>

<div class="main-content">
  <%- include('./topbar') %>
  <%- include('./alerts') %>

  <div class="page-content">
    <div class="card-custom">
      <div class="card-header">
        <span><i class="fas fa-book me-2"></i>Subjects</span>
        <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addSubjectModal">
          <i class="fas fa-plus me-1"></i>Add Subject
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table data-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Code</th>
                <th>Subject Name</th>
                <th>Units</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof subjects !== 'undefined' && subjects.length > 0) { %>
                <% subjects.forEach((sub, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= sub.subjectCode %></strong></td>
                  <td><%= sub.subjectName %></td>
                  <td><%= sub.units %></td>
                  <td><span class="badge badge-role badge-<%= sub.status %>"><%= sub.status %></span></td>
                  <td>
                    <div class="d-flex gap-1">
                      <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editSubject<%= sub._id %>" title="Edit">
                        <i class="fas fa-edit"></i>
                      </button>
                      <form action="/subjects/delete/<%= sub._id %>" method="POST" onsubmit="return confirm('Archive this subject?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-archive"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>

                <!-- EDIT MODAL -->
                <div class="modal fade" id="editSubject<%= sub._id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Subject</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/subjects/update/<%= sub._id %>" method="POST">
                        <div class="modal-body">
                          <div class="row g-3">
                            <div class="col-md-6">
                              <label class="form-label">Subject Code</label>
                              <input type="text" name="subjectCode" class="form-control" value="<%= sub.subjectCode %>" required />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Units</label>
                              <input type="number" name="units" class="form-control" value="<%= sub.units %>" required />
                            </div>
                            <div class="col-12">
                              <label class="form-label">Subject Name</label>
                              <input type="text" name="subjectName" class="form-control" value="<%= sub.subjectName %>" required />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Status</label>
                              <select name="status" class="form-select">
                                <option value="active" <%= sub.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="inactive" <%= sub.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Update</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                <% }) %>
              <% } else { %>
                <tr><td colspan="6" class="text-center text-muted py-4">No subjects found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADD SUBJECT MODAL -->
<div class="modal fade" id="addSubjectModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add Subject</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/subjects/add" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Subject Code <span class="text-danger">*</span></label>
              <input type="text" name="subjectCode" class="form-control" placeholder="ITE 400" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Units <span class="text-danger">*</span></label>
              <input type="number" name="units" class="form-control" placeholder="3" required />
            </div>
            <div class="col-12">
              <label class="form-label">Subject Name <span class="text-danger">*</span></label>
              <input type="text" name="subjectName" class="form-control" placeholder="System Integration and Architecture" required />
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Units — max 1 digit, only 1-3
  document.addEventListener('input', function (e) {
    if (e.target && e.target.name === 'units') {
      e.target.value = e.target.value.replace(/[^1-3]/g, '').slice(0, 1);
    }
  });

  
</script>
<script>
  // Subject Code — max 7 characters (works on all modals)
  document.addEventListener('input', function (e) {
    if (e.target && e.target.name === 'subjectCode') {
      e.target.value = e.target.value.slice(0, 7).toUpperCase();
    }
  });
</script>