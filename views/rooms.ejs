<% layout('main') %>

<%- include('./sidebar') %>

<div class="main-content">
  <%- include('./topbar') %>
  <%- include('./alerts') %>

  <div class="page-content">
    <div class="card-custom">
      <div class="card-header">
        <span><i class="fas fa-door-open me-2"></i>Rooms</span>
        <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addRoomModal">
          <i class="fas fa-plus me-1"></i>Add Room
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table data-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Room Number</th>
                <th>Building</th>
                <th>Capacity</th>
                <th>Assigned Schedules</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof rooms !== 'undefined' && rooms.length > 0) { %>
                <% rooms.forEach((rm, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= rm.roomNumber %></strong></td>
                  <td><%= rm.building || '-' %></td>
                  <td><%= rm.capacity || '-' %></td>
                  <td><span class="badge bg-info rounded-pill"><%= rm.scheduleCount %></span></td>
                  <td><span class="badge badge-role badge-<%= rm.status %>"><%= rm.status %></span></td>
                  <td>
                    <div class="d-flex gap-1">
                      <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editRoom<%= rm._id %>">
                        <i class="fas fa-edit"></i>
                      </button>
                      <form action="/rooms/delete/<%= rm._id %>" method="POST" onsubmit="return confirm('Archive this room?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-archive"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>

                <!-- EDIT MODAL -->
                <div class="modal fade" id="editRoom<%= rm._id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Room</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/rooms/update/<%= rm._id %>" method="POST">
                        <div class="modal-body">
                          <div class="row g-3">
                            <div class="col-md-6">
                              <label class="form-label">Room Number</label>
                              <input type="text" name="roomNumber" class="form-control" value="<%= rm.roomNumber %>" required />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Building</label>
                              <input type="text" name="building" class="form-control" value="<%= rm.building || '' %>" />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Capacity</label>
                              <input type="number" name="capacity" class="form-control" value="<%= rm.capacity || '' %>" />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Status</label>
                              <select name="status" class="form-select">
                                <option value="active" <%= rm.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="inactive" <%= rm.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Update</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                <% }) %>
              <% } else { %>
                <tr><td colspan="7" class="text-center text-muted py-4">No rooms found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADD ROOM MODAL -->
<div class="modal fade" id="addRoomModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add Room</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/rooms/add" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Room Number <span class="text-danger">*</span></label>
              <input type="text" name="roomNumber" class="form-control" placeholder="404" required />
            </div>
            <div class="col-md-6"style="display: none;">
              <label class="form-label">Building</label>
              <input type="text" name="building" class="form-control" placeholder="South"value="South" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Capacity</label>
              <input type="number" name="capacity" class="form-control" min="1" placeholder="50" />
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('input', function (e) {
    if (e.target && e.target.name === 'capacity') {
      e.target.value = e.target.value.replace(/[^0-9]/g, '').slice(0, 2);
      if (Number(e.target.value) > 50) {
        e.target.value = '50';
      }
    }
  });
</script>
