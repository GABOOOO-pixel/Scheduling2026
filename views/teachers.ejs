<% layout('main') %>

<%- include('./sidebar') %>

<div class="main-content">
  <%- include('./topbar') %>
  <%- include('./alerts') %>

  <div class="page-content">
    <div class="card-custom">
      <div class="card-header">
        <span><i class="fas fa-chalkboard-teacher me-2"></i>Teachers</span>
        <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addTeacherModal">
          <i class="fas fa-plus me-1"></i>Add Teacher
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table data-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Department</th>
                <th>Email</th>
                <th>Contact</th>
                <th>Schedules</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof teachers !== 'undefined' && teachers.length > 0) { %>
                <% teachers.forEach((t, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= t.lname %>, <%= t.fname %></strong> <%= t.mname || '' %> <%= t.suffix || '' %></td>
                  <td><%= t.department || '-' %></td>
                  <td><%= t.email || '-' %></td>
                  <td><%= t.contact || '-' %></td>
                  <td><span class="badge bg-primary rounded-pill"><%= t.scheduleCount %></span></td>
                  <td><span class="badge badge-role badge-<%= t.status %>"><%= t.status %></span></td>
                  <td>
                    <div class="d-flex gap-1">
                      <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editTeacher<%= t._id %>">
                        <i class="fas fa-edit"></i>
                      </button>
                      <form action="/teachers/delete/<%= t._id %>" method="POST" onsubmit="return confirm('Archive this teacher?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-archive"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>

                <!-- EDIT MODAL -->
                <div class="modal fade" id="editTeacher<%= t._id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Teacher</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/teachers/update/<%= t._id %>" method="POST">
                        <div class="modal-body">
                          <div class="row g-3">
                            <!-- Row 1: First Name | Last Name -->
                            <div class="col-md-6">
                              <label class="form-label">First Name <span class="text-danger">*</span></label>
                              <input type="text" name="fname" class="form-control" value="<%= t.fname %>" required
                                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Last Name <span class="text-danger">*</span></label>
                              <input type="text" name="lname" class="form-control" value="<%= t.lname %>" required
                                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
                            </div>
                            <!-- Row 2: Middle Name | Suffix -->
                            <div class="col-md-6">
                              <label class="form-label">Middle Name</label>
                              <input type="text" name="mname" class="form-control" value="<%= t.mname || '' %>"
                                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Suffix</label>
                              <input type="text" name="suffix" class="form-control" value="<%= t.suffix || '' %>"
                                placeholder="Jr., Sr., III..."
                                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
                            </div>
                            <!-- Row 3: Department | Email -->
                            <div class="col-md-6">
                              <label class="form-label">Department</label>
                              <input type="hidden" name="department" value="CIT" />
                              <p class="form-control-plaintext fw-semibold">CIT</p>
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Email</label>
                              <input type="email" name="email" class="form-control" value="<%= t.email || '' %>" />
                            </div>
                            <!-- Row 4: Contact | Status -->
                            <div class="col-md-6">
                              <label class="form-label">Contact</label>
                              <input type="text" name="contact" class="form-control" value="<%= t.contact || '' %>"
                                maxlength="11"
                                onkeypress="return /[0-9]/i.test(event.key)"
                                oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Status</label>
                              <select name="status" class="form-select">
                                <option value="active" <%= t.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="inactive" <%= t.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Update</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                <% }) %>
              <% } else { %>
                <tr><td colspan="8" class="text-center text-muted py-4">No teachers found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADD TEACHER MODAL -->
<div class="modal fade" id="addTeacherModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add Teacher</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/teachers/add" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <!-- Row 1: First Name | Last Name -->
            <div class="col-md-6">
              <label class="form-label">First Name <span class="text-danger">*</span></label>
              <input type="text" name="fname" class="form-control" required
                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Last Name <span class="text-danger">*</span></label>
              <input type="text" name="lname" class="form-control" required
                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
            </div>
            <!-- Row 2: Middle Name | Suffix -->
            <div class="col-md-6">
              <label class="form-label">Middle Name</label>
              <input type="text" name="mname" class="form-control"
                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
            </div>
            <div class="col-md-6">
              <label class="form-label">Suffix</label>
              <input type="text" name="suffix" class="form-control"
                placeholder="Jr., Sr., III..."
                onkeypress="return /[a-zA-Z\s.]/i.test(event.key)"
                oninput="this.value = this.value.replace(/[^a-zA-Z\s.]/g, '')" />
            </div>
            <!-- Row 3: Department | Email -->
            <div class="col-md-6">
              <label class="form-label">Department</label>
              <input type="hidden" name="department" value="CIT" />
              <p class="form-control-plaintext fw-semibold">CIT</p>
            </div>
            <div class="col-md-6">
              <label class="form-label">Email</label>
              <input type="email" name="email" class="form-control" />
            </div>
            <!-- Row 4: Contact -->
            <div class="col-md-6">
              <label class="form-label">Contact</label>
              <input 
                type="text" 
                name="contact" 
                class="form-control" 
                placeholder="09123456789"
                maxlength="11"
                onkeypress="return /[0-9]/i.test(event.key)"
                oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                required
              />
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('input', function (e) {
    // Block numbers on name fields
    if (['fname', 'mname', 'lname', 'suffix'].includes(e.target.name)) {
      e.target.value = e.target.value.replace(/[^a-zA-Z\s.]/g, '');
    }

    // Numbers only for contact
    if (e.target.name === 'contact') {
      e.target.value = e.target.value.replace(/[^0-9]/g, '');
      if (e.target.value.length > 11) {
        e.target.value = e.target.value.slice(0, 11);
      }
    }
  });

  // Also block on keydown for immediate feedback
  document.addEventListener('keydown', function (e) {
    if (['fname', 'mname', 'lname', 'suffix'].includes(e.target.name)) {
      if (e.key >= '0' && e.key <= '9') {
        e.preventDefault();
      }
    }
  });
</script>