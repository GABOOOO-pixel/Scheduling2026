<% layout('main') %>

<%- include('./sidebar') %>

<div class="main-content">
  <%- include('./topbar') %>
  <%- include('./alerts') %>

  <div class="page-content">
    <div class="row justify-content-center">
      <div class="col-md-8 col-lg-6">
        <div class="card-custom">
          <div class="card-header">
            <span><i class="fas fa-user-circle me-2"></i>My Profile</span>
          </div>
          <div class="card-body">

            <% if (!fullUser) { %>
              <p class="text-center text-muted">No user data available.</p>
            <% } else {
              const displayEmail   = fullUser.email || (fullUser.teacherId && fullUser.teacherId.email) || null;
              const displayContact = (fullUser.teacherId && fullUser.teacherId.contact) || null;
              const displayDept    = (fullUser.teacherId && fullUser.teacherId.department) || null;
            %>

              <div class="text-center mb-4">
                <div class="mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem; background: var(--primary); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800;">
                  <%= fullUser.fname.charAt(0).toUpperCase() %>
                </div>
                <h5 style="font-weight: 700; margin-bottom: 0.25rem;"><%= fullUser.fname %> <%= fullUser.lname %></h5>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.25rem;">
                  <i class="fas fa-user me-1"></i>@<%= fullUser.username %>
                </p>
                <% if (displayEmail) { %>
                  <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.25rem;">
                    <i class="fas fa-envelope me-1"></i><%= displayEmail %>
                  </p>
                <% } %>
                <% if (displayContact) { %>
                  <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.25rem;">
                    <i class="fas fa-phone me-1"></i><%= displayContact %>
                  </p>
                <% } %>
                <% if (displayDept) { %>
                  <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 0.5rem;">
                    <i class="fas fa-building me-1"></i><%= displayDept %>
                  </p>
                <% } %>
                <span class="badge badge-role badge-<%= fullUser.role %>">
                  <%= fullUser.role.replace(/_/g, ' ') %>
                </span>
              </div>

              <hr />

              <h6 style="font-weight: 700; margin-bottom: 1rem;"><i class="fas fa-key me-2"></i>Change Password</h6>
              <form action="/profile/change-password" method="POST">
                <div class="mb-3">
                  <label class="form-label">Current Password</label>
                  <input type="password" name="currentPassword" class="form-control" required />
                </div>
                <div class="mb-3">
                  <label class="form-label">New Password</label>
                  <input type="password" name="newPassword" class="form-control" required minlength="6" />
                </div>
                <div class="mb-3">
                  <label class="form-label">Confirm New Password</label>
                  <input type="password" name="confirmPassword" class="form-control" required minlength="6" />
                </div>
                <button type="submit" class="btn btn-primary-custom w-100">
                  <i class="fas fa-save me-1"></i>Update Password
                </button>
              </form>

            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
