<% layout('main') %>

<%- include('./sidebar') %>

<div class="main-content">
  <%- include('./topbar') %>
  <%- include('./alerts') %>

  <div class="page-content">
    <div class="card-custom">
      <div class="card-header">
        <span><i class="fas fa-users-cog me-2"></i>User Accounts</span>
        <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addUserModal">
          <i class="fas fa-plus me-1"></i>Add User
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table data-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Username</th>
                <th>Full Name</th>
                <th>Role</th>
                <th>Linked Teacher</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof users !== 'undefined' && users.length > 0) { %>
                <% users.forEach((u, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= u.username %></strong></td>
                  <td><%= u.lname %>, <%= u.fname %></td>
                  <td>
                    <span class="badge badge-role" style="
                      <% if (u.role === 'super_admin') { %>background: #fce7f3; color: #9d174d;
                      <% } else if (u.role === 'admin') { %>background: #dbeafe; color: #1e40af;
                      <% } else { %>background: #d1fae5; color: #065f46;<% } %>
                    "><%= u.role.replace('_', ' ') %></span>
                  </td>
                  <td>
                    <% if (u.teacherId) { %>
                      <%= u.teacherId.lname %>, <%= u.teacherId.fname %>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </td>
                  <td><span class="badge badge-role badge-<%= u.status %>"><%= u.status %></span></td>
                  <td>
                    <div class="d-flex gap-1">
                      <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editUser<%= u._id %>">
                        <i class="fas fa-edit"></i>
                      </button>
                      <form action="/users/delete/<%= u._id %>" method="POST" onsubmit="return confirm('Archive this user?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-archive"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>

                <!-- EDIT USER MODAL -->
                <div class="modal fade" id="editUser<%= u._id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit User - <%= u.username %></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/users/update/<%= u._id %>" method="POST">
                        <div class="modal-body">
                          <div class="row g-3">
                            <div class="col-md-6">
                              <label class="form-label">Username</label>
                              <input type="text" name="username" class="form-control" value="<%= u.username %>" required />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">New Password <small class="text-muted">(leave blank to keep)</small></label>
                              <div class="col-md-6" style="width: 100% !important;">
                                <div class="input-icon-wrapper" style="position: relative; width: 100% !important;">
                                    <input 
                                        type="password" 
                                        name="password" 
                                        class="form-control login-input" 
                                        placeholder="••••••••" 
                                         
                                    />
                                    <span class="toggle-password-btn" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); cursor: pointer; color: #94a3b8; z-index: 10;">
                                        <i class="fas fa-eye eye-icon"></i>
                                    </span>
                                </div>
                            </div>
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">First Name</label>
                              <input type="text" name="fname" class="form-control" value="<%= u.fname %>" required />
                            </div>
                            <div class="col-md-6">
                              <label class="form-label">Last Name</label>
                              <input type="text" name="lname" class="form-control" value="<%= u.lname %>" required />
                            </div>
                            <div class="col-md-4">
                              <label class="form-label">Role</label>
                              <select name="role" class="form-select" required>
                                <option value="super_admin" <%= u.role === 'super_admin' ? 'selected' : '' %>>Super Admin</option>
                                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                <option value="faculty" <%= u.role === 'faculty' ? 'selected' : '' %>>Faculty</option>
                              </select>
                            </div>
                            <div class="col-md-4">
                              <label class="form-label">Link to Teacher</label>
                              <select name="teacherId" class="form-select">
                                <option value="">-- None --</option>
                                <% if (typeof teachers !== 'undefined') { %>
                                  <% teachers.forEach(t => { %>
                                    <option value="<%= t._id %>" <%= u.teacherId && u.teacherId._id.toString() === t._id.toString() ? 'selected' : '' %>>
                                      <%= t.lname %>, <%= t.fname %>
                                    </option>
                                  <% }) %>
                                <% } %>
                              </select>
                            </div>
                            <div class="col-md-4">
                              <label class="form-label">Status</label>
                              <select name="status" class="form-select">
                                <option value="active" <%= u.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="inactive" <%= u.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Update</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                <% }) %>
              <% } else { %>
                <tr><td colspan="7" class="text-center text-muted py-4">No users found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADD USER MODAL -->
<div class="modal fade" id="addUserModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add User Account</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/users/add" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Username <span class="text-danger">*</span></label>
              <input type="text" name="username" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Password <span class="text-danger">*</span></label>
              <div class="col-md-6" style="width: 100% !important;">
                 <div class="input-icon-wrapper" style="position: relative; width: 100% !important;">
                    <input 
                        type="password" 
                        name="password" 
                        class="form-control login-input" 
                        placeholder="••••••••" 
                        required 
                    />
                    <span class="toggle-password-btn" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); cursor: pointer; color: #94a3b8; z-index: 10;">
                        <i class="fas fa-eye eye-icon"></i>
                    </span>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label">First Name <span class="text-danger">*</span></label>
              <input type="text" name="fname" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Last Name <span class="text-danger">*</span></label>
              <input type="text" name="lname" class="form-control" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Role <span class="text-danger">*</span></label>
              <select name="role" class="form-select" required>
                <option value="">-- Select Role --</option>
                <option value="super_admin">Super Admin</option>
                <option value="admin">Admin</option>
                <option value="faculty">Faculty</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Link to Teacher <small class="text-muted">(for faculty)</small></label>
              <select name="teacherId" class="form-select">
                <option value="">-- None --</option>
                <% if (typeof teachers !== 'undefined') { %>
                  <% teachers.forEach(t => { %>
                    <option value="<%= t._id %>"><%= t.lname %>, <%= t.fname %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Create User</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
    document.addEventListener('click', function (e) {
        // I-check kung ang pinindot ay ang toggle button o yung icon sa loob nito
        const btn = e.target.closest('.toggle-password-btn');
        
        if (btn) {
            // Hanapin ang input field na kasama sa parehong wrapper
            const container = btn.closest('.input-icon-wrapper');
            const passwordInput = container.querySelector('input');
            const eyeIcon = btn.querySelector('.eye-icon');

            // I-toggle ang type attribute
            const isPassword = passwordInput.getAttribute('type') === 'password';
            passwordInput.setAttribute('type', isPassword ? 'text' : 'password');

            // I-toggle ang icon class
            eyeIcon.classList.toggle('fa-eye');
            eyeIcon.classList.toggle('fa-eye-slash');
        }
    });
</script>