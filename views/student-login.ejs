<% layout('public') %>

<style>
  .login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: 
        radial-gradient(circle at 10% 5%, #052e16, transparent 25%),
        radial-gradient(circle at 95% 90%, #15803d, transparent 24%),
        radial-gradient(circle at 10% 60%, #14532d, transparent 30%);
    background-blend-mode: lighten;
    backdrop-filter: blur(10px);
    background-color: #052e16;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .login-wrapper::before {
    content: '';
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(16, 185, 129, 0.12) 0%, transparent 70%);
    top: -100px;
    right: -100px;
    border-radius: 50%;
  }
  .login-card {
    background: rgba(255,255,255,0.97);
    border-radius: 20px;
    padding: 2.5rem;
    width: 100%;
    max-width: 520px;
    box-shadow: 0 25px 60px rgba(0,0,0,0.3);
    position: relative;
    z-index: 1;
  }
  .login-card .brand {
    text-align: center;
    margin-bottom: 2rem;
  }
  .login-card .brand h2 {
    font-weight: 800;
    font-size: 1.75rem;
    color: #0f172a;
  }
  .login-card .brand h2 span { color: #f59e0b; }
  .login-card .brand p {
    color: rgb(4, 40, 4);
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }
  .badge-student {
    display: inline-block;
    background: #d1fae5;
    color: #065f46;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 0.5rem;
  }
  .logo-card {
    display: flex !important;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 5px;
  }
  .logo { height: 95px; width: 95px; }
  .login-input {
    border: 2px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.7rem 1rem 0.7rem 2.75rem;
    font-size: 0.9rem;
    transition: all 0.2s;
    background: #f8fafc;
    padding-right: 3rem !important;
  }
  .login-input:focus {
    border-color: #065f46;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(6, 95, 70, 0.08);
  }
  .input-icon-wrapper {
    position: relative;
  }
  .input-icon-wrapper i {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .btn-toggle-pass {
    position: absolute;
    right: 2.7rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #94a3b8;
    cursor: pointer;
    padding: 0;
    z-index: 10;
    transition: color 0.2s;
  }
  .btn-toggle-pass:hover { color: #065f46; }
  .btn-login {
    background: #052e16;
    color: #fff;
    border: none;
    padding: 0.75rem;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    width: 100%;
    transition: all 0.2s;
  }
  .btn-login:hover {
    background: #14532d;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(5, 46, 22, 0.3);
  }
  .links-section {
    text-align: center;
    margin-top: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e2e8f0;
  }
  .links-section a {
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    margin: 0 0.5rem;
  }
  .links-section a.register-link { color: #002707; }
  .links-section a.register-link:hover { color: #d97706; text-decoration: underline; }
  .links-section a.admin-link { color: #94a3b8; }
  .links-section a.admin-link:hover { color: #64748b; text-decoration: underline; }
  
  .fg-div{
    margin-top: 5px;
    display: flex !important;
    justify-content: center;
    align-items: center;
    width: 100%;
  }
  .fg {
    text-decoration: none;
    width: auto;
    color:#1e3a5f ;
    font-size: 14px;
  }
</style>

<div class="login-wrapper">
  <div class="login-card">
    <div class="logo-card">
      <img src="/images/logo.png" alt="" class="logo">
    </div>
    <div class="brand">
      <h2><span>CIT </span>Schedule</h2>
      <p>Student Portal</p>
      <div class="badge-student"><i class="fas fa-user-graduate me-1"></i>Student Login</div>
    </div>

    <%- include('./alerts') %>

    <form action="/student-login" method="POST">
      <div class="mb-3">
        <label class="form-label" style="font-weight: 600; font-size: 0.8rem;">Student Number</label>
        <div class="input-icon-wrapper">
          <i class="fas fa-id-card"></i>
          <input type="text" name="studentNumber" id="studentNumber" class="form-control login-input" placeholder="00-0000-000000" required />
        </div>
      </div>
      <div class="mb-4">
        <label class="form-label" style="font-weight: 600; font-size: 0.8rem;">Password</label>
        <div class="input-icon-wrapper">
          <i class="fas fa-lock"></i>
          <input type="password" name="password" id="passwordInput" class="form-control login-input" placeholder="Enter password" required />
          <button type="button" id="togglePassword" class="btn-toggle-pass">
            <i class="fas fa-eye" id="eyeIcon"></i>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-login">
        <i class="fas fa-sign-in-alt me-2"></i>Sign In
      </button>
      
      <div class="fg-div">
        <a href="/fg" class="fg">Forgot Password</a>
      </div>
    </form>

    <div class="links-section">
      <p style="font-size: 0.8rem; color: #25352e; margin-bottom: 0.5rem;">Don't have an account?</p>
      <a href="/student-form" class="register-link"><i class="fas fa-edit me-1"></i>Register Here</a>
      <span style="color: #e2e8f0;">|</span>
      <a href="/" class="admin-link"><i class="fas fa-lock me-1"></i>Admin Login</a>
    </div>
  </div>
</div>

<script>
  // Toggle password visibility
  const togglePassword = document.querySelector('#togglePassword');
  const passwordInput = document.querySelector('#passwordInput');
  const eyeIcon = document.querySelector('#eyeIcon');
  togglePassword.addEventListener('click', function () {
    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
    passwordInput.setAttribute('type', type);
    eyeIcon.classList.toggle('fa-eye');
    eyeIcon.classList.toggle('fa-eye-slash');
  });

  // Auto-format student number to 00-0000-000000
  const studentInput = document.getElementById('studentNumber');
  studentInput.addEventListener('keypress', function(e) {
    if (!/[\d-]/.test(String.fromCharCode(e.which))) e.preventDefault();
  });
  studentInput.addEventListener('paste', function(e) {
    const paste = (e.clipboardData || window.clipboardData).getData('text');
    if (!/^[\d-]+$/.test(paste)) e.preventDefault();
  });
  studentInput.addEventListener('input', function() {
    let digits = this.value.replace(/\D/g, '').slice(0, 12);
    if (digits.length <= 2) this.value = digits;
    else if (digits.length <= 6) this.value = digits.slice(0,2) + '-' + digits.slice(2);
    else this.value = digits.slice(0,2) + '-' + digits.slice(2,6) + '-' + digits.slice(6);
  });
</script>
