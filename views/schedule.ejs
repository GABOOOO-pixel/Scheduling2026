<% layout('main') %>

<%- include('./sidebar') %>

<div class="main-content">
  <%- include('./topbar') %>
  <%- include('./alerts') %>

  <div class="page-content">
    <div class="card-custom">
      <div class="card-header">
        <span><i class="fas fa-calendar-alt me-2"></i>Schedule Management</span>
        <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addScheduleModal">
          <i class="fas fa-plus me-1"></i>Add Schedule
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table data-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Subject</th>
                <th>Teacher</th>
                <th>Section</th>
                <th>Day</th>
                <th>Time</th>
                <th>Room</th>
                <th>Year / Sem</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof schedules !== 'undefined' && schedules.length > 0) { %>
                <% schedules.forEach((sched, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td>
                    <strong><%= sched.subjectId ? sched.subjectId.subjectCode : 'N/A' %></strong><br/>
                    <small class="text-muted"><%= sched.subjectId ? sched.subjectId.subjectName : '' %></small>
                  </td>
                  <td><%= sched.teacherId ? sched.teacherId.lname + ', ' + sched.teacherId.fname : 'N/A' %></td>
                  <td><%= sched.sectionId ? sched.sectionId.sectionName : 'N/A' %></td>
                  <td><%= sched.day %></td>
                  <td><%= sched.timeFrom %> - <%= sched.timeTo %></td>
                  <td><%= sched.roomId ? sched.roomId.roomNumber : 'TBA' %></td>
                  <td><%= sched.yearLevel %>Y / Sem <%= sched.semester %><br/><small class="text-muted"><%= sched.schoolYear %></small></td>
                  <td>
                    <span class="badge badge-role badge-<%= sched.status %>"><%= sched.status %></span>
                  </td>
                  <td>
                    <div class="d-flex gap-1">
                      <a href="/schedule/edit/<%= sched._id %>" class="btn btn-sm btn-outline-primary" title="Edit">
                        <i class="fas fa-edit"></i>
                      </a>
                      <form action="/schedule/delete/<%= sched._id %>" method="POST" onsubmit="return confirm('Archive this schedule?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Archive">
                          <i class="fas fa-archive"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="10" class="text-center text-muted py-4">No schedules found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADD SCHEDULE MODAL -->
<div class="modal fade" id="addScheduleModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add New Schedule</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/schedule/add" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Subject <span class="text-danger">*</span></label>
              <select name="subjectId" class="form-select" required>
                <option value="">-- Select Subject --</option>
                <% if (typeof subjects !== 'undefined') { %>
                  <% subjects.forEach(sub => { %>
                    <option value="<%= sub._id %>"><%= sub.subjectCode %> - <%= sub.subjectName %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Teacher <span class="text-danger">*</span></label>
              <select name="teacherId" class="form-select" required>
                <option value="">-- Select Teacher --</option>
                <% if (typeof teachers !== 'undefined') { %>
                  <% teachers.forEach(t => { %>
                    <option value="<%= t._id %>"><%= t.lname %>, <%= t.fname %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Section <span class="text-danger">*</span></label>
              <select name="sectionId" class="form-select" required>
                <option value="">-- Select Section --</option>
                <% if (typeof sections !== 'undefined') { %>
                  <% sections.forEach(sec => { %>
                    <option value="<%= sec._id %>"><%= sec.sectionName %> (Year <%= sec.yearLevel %>)</option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Room</label>
              <select name="roomId" class="form-select">
                <option value="">-- Select Room --</option>
                <% if (typeof rooms !== 'undefined') { %>
                  <% rooms.forEach(rm => { %>
                    <option value="<%= rm._id %>"><%= rm.roomNumber %> <%= rm.building ? '(' + rm.building + ')' : '' %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Day <span class="text-danger">*</span></label>
              <select name="day" class="form-select" required>
                <option value="">-- Select Day --</option>
                <option>Monday</option>
                <option>Tuesday</option>
                <option>Wednesday</option>
                <option>Thursday</option>
                <option>Friday</option>
                <option>Saturday</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Time From <span class="text-danger">*</span></label>
              <input type="time" name="timeFrom" class="form-control" required />
            </div>
            <div class="col-md-4">
              <label class="form-label">Time To <span class="text-danger">*</span></label>
              <input type="time" name="timeTo" class="form-control" required />
            </div>
            <div class="col-md-4">
              <label class="form-label">Year Level <span class="text-danger">*</span></label>
              <select name="yearLevel" class="form-select" required>
                <option value="">Select</option>
                <option value="1">1st Year</option>
                <option value="2">2nd Year</option>
                <option value="3">3rd Year</option>
                <option value="4">4th Year</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Semester <span class="text-danger">*</span></label>
              <select name="semester" class="form-select" required>
                <option value="">Select</option>
                <option value="1">1st Semester</option>
                <option value="2">2nd Semester</option>
                <option value="3">Summer</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">School Year <span class="text-danger">*</span></label>
              <input type="text" name="schoolYear" class="form-control" placeholder="2025-2026" required />
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Save Schedule</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Gamitin ang standard JavaScript para walang conflict sa jQuery version
  document.addEventListener('input', function (e) {
    if (e.target && e.target.name === 'schoolYear') {
      let input = e.target;
      // Burahin ang lahat ng hindi numero
      input.value = input.value.replace(/[^0-9-]/g, '');
      
      // Siguraduhin na 11 digits lang
      if (input.value.length > 11) {
        input.value = input.value.slice(0, 11);
      }
    }
  });
</script>
