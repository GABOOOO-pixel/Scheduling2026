<% layout('main') %>

<%- include('./sidebar') %>

<div class="main-content">
  <%- include('./topbar') %>
  <%- include('./alerts') %>

  <div class="page-content">
    <div class="card-custom">
      <div class="card-header">
        <span><i class="fas fa-layer-group me-2"></i>Sections</span>
        <button class="btn btn-accent btn-sm" data-bs-toggle="modal" data-bs-target="#addSectionModal">
          <i class="fas fa-plus me-1"></i>Add Section
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table data-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Section Name</th>
                <th>Year Level</th>
                <th>Program</th>
                <th>Students</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (typeof sections !== 'undefined' && sections.length > 0) { %>
                <% sections.forEach((sec, i) => { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td><strong><%= sec.sectionName %></strong></td>
                  <td>Year <%= sec.yearLevel %></td>
                  <td><%= sec.program %></td>
                  <td><span class="badge bg-success rounded-pill"><%= sec.studentCount %></span></td>
                  <td><span class="badge badge-role badge-<%= sec.status %>"><%= sec.status %></span></td>
                  <td>
                    <div class="d-flex gap-1">
                      <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editSection<%= sec._id %>">
                        <i class="fas fa-edit"></i>
                      </button>
                      <form action="/sections/delete/<%= sec._id %>" method="POST" onsubmit="return confirm('Archive this section?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-archive"></i></button>
                      </form>
                    </div>
                  </td>
                </tr>

                <!-- EDIT MODAL -->
                <div class="modal fade" id="editSection<%= sec._id %>" tabindex="-1">
                  <div class="modal-dialog">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Section</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                      </div>
                      <form action="/sections/update/<%= sec._id %>" method="POST">
                        <div class="modal-body">
                          <div class="row g-3">
                            <div class="col-md-12">
                              <label class="form-label">Section Name</label>
                              <input type="text" name="sectionName" class="form-control" value="<%= sec.sectionName %>" required />
                            </div>
                            <div class="col-md-4">
                              <label class="form-label">Year Level</label>
                              <select name="yearLevel" class="form-select" required>
                                <% [1,2,3,4].forEach(y => { %>
                                  <option value="<%= y %>" <%= sec.yearLevel === y ? 'selected' : '' %>><%= y %></option>
                                <% }) %>
                              </select>
                            </div>
                            <div class="col-md-4">
                              <label class="form-label">Program</label>
                              <input type="text" name="program" class="form-control" value="<%= sec.program %>" required />
                            </div>
                            <div class="col-md-4">
                              <label class="form-label">Status</label>
                              <select name="status" class="form-select">
                                <option value="active" <%= sec.status === 'active' ? 'selected' : '' %>>Active</option>
                                <option value="inactive" <%= sec.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                              </select>
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Update</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                <% }) %>
              <% } else { %>
                <tr><td colspan="7" class="text-center text-muted py-4">No sections found.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ADD SECTION MODAL -->
<div class="modal fade" id="addSectionModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-plus-circle me-2"></i>Add Section</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/sections/add" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Section Name <span class="text-danger">*</span></label>
              <input type="text" name="sectionName" class="form-control" placeholder="BSIT 3A" required />
            </div>
            <div class="col-md-6">
              <label class="form-label">Year Level <span class="text-danger">*</span></label>
              <select name="yearLevel" class="form-select" required>
                <option value="">Select</option>
                <option value="1">1st Year</option>
                <option value="2">2nd Year</option>
                <option value="3">3rd Year</option>
                <option value="4">4th Year</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Program <span class="text-danger">*</span></label>
              <input type="text" name="program" class="form-control" placeholder="BSIT" required />
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-accent btn-sm"><i class="fas fa-save me-1"></i>Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
